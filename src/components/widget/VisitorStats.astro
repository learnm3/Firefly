---
import { footerConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

const statsConfig = footerConfig.visitorStats;
const isEnabled = statsConfig?.enable && statsConfig?.serverURL;
const serverURL = statsConfig?.serverURL || "";

// 构建时计算日期 key，也作为回退值
const now = new Date();
const dailyKey = `_site_stats/daily/${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}-${String(now.getDate()).padStart(2, "0")}`;
const monthlyKey = `_site_stats/monthly/${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}`;
const totalKey = "_site_stats/total";
---

{
  isEnabled && (
    <div
      id="visitor-stats"
      class="visitor-stats flex flex-wrap items-center justify-center gap-x-5 gap-y-1 mt-2 text-sm text-black/40 dark:text-white/40"
    >
      <span class="visitor-stat-item inline-flex items-center gap-1">
        <span class="visitor-stat-label">{i18n(I18nKey.visitorToday)}</span>
        <span class="visitor-stat-count font-medium text-black/55 dark:text-white/55" id="visitor-count-today">--</span>
      </span>
      <span class="visitor-stat-item inline-flex items-center gap-1">
        <span class="visitor-stat-label">{i18n(I18nKey.visitorThisMonth)}</span>
        <span class="visitor-stat-count font-medium text-black/55 dark:text-white/55" id="visitor-count-month">--</span>
      </span>
      <span class="visitor-stat-item inline-flex items-center gap-1">
        <span class="visitor-stat-label">{i18n(I18nKey.visitorTotal)}</span>
        <span class="visitor-stat-count font-medium text-black/55 dark:text-white/55" id="visitor-count-total">--</span>
      </span>
    </div>
  )
}

<script define:vars={{ serverURL, dailyKey, monthlyKey, totalKey }}>
  (function initVisitorStats() {
    const statsEl = document.getElementById("visitor-stats");
    if (!statsEl || !serverURL) return;

    // 客户端重新计算日期 key（确保时区正确）
    const nowDate = new Date();
    const todayKey = `_site_stats/daily/${nowDate.getFullYear()}-${String(nowDate.getMonth() + 1).padStart(2, "0")}-${String(nowDate.getDate()).padStart(2, "0")}`;
    const monthKey = `_site_stats/monthly/${nowDate.getFullYear()}-${String(nowDate.getMonth() + 1).padStart(2, "0")}`;

    const API = serverURL.replace(/\/$/, "");

    // 从 Waline API 获取计数
    async function fetchCount(path) {
      try {
        const res = await fetch(`${API}/api/article?path=${encodeURIComponent(path)}`, {
          // 加 cache-bust 避免缓存
          cache: "no-cache",
        });
        if (!res.ok) return 0;
        const data = await res.json();
        // Waline 返回的是记录数组，每个 pageview 一条记录
        if (Array.isArray(data)) return data.length;
        // 有些版本返回 { count: number }
        if (data && typeof data === "object" && "count" in data && typeof data.count === "number") {
          return data.count;
        }
        // 纯数字
        if (typeof data === "number") return data;
        return 0;
      } catch {
        return 0;
      }
    }

    // 递增 Waline 计数器
    async function incrementCounter(path) {
      try {
        await fetch(`${API}/api/article`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ path, time: Math.floor(Date.now() / 1000) }),
        });
      } catch {
        // 静默失败，不影响页面
      }
    }

    // 更新页面显示
    async function updateDisplay() {
      const [today, month, total] = await Promise.all([
        fetchCount(todayKey),
        fetchCount(monthKey),
        fetchCount(totalKey),
      ]);

      const todayEl = document.getElementById("visitor-count-today");
      const monthEl = document.getElementById("visitor-count-month");
      const totalEl = document.getElementById("visitor-count-total");

      if (todayEl) todayEl.textContent = String(today);
      if (monthEl) monthEl.textContent = String(month);
      if (totalEl) totalEl.textContent = String(total);
    }

    // 主流程：同一浏览器会话内只计数一次（避免 SPA 导航重复计数）
    async function run() {
      const sessionKey = "_vs_counted_day";
      const countedDay = sessionStorage.getItem(sessionKey);

      // 当天的首次访问才递增计数器
      if (countedDay !== todayKey) {
        await Promise.all([
          incrementCounter(todayKey),
          incrementCounter(monthKey),
          incrementCounter(totalKey),
        ]);
        sessionStorage.setItem(sessionKey, todayKey);
      }

      // 始终获取最新计数并更新显示
      await updateDisplay();
    }

    run();
  })();
</script>

<style is:global>
  .visitor-stat-item {
    white-space: nowrap;
  }
  .visitor-stat-count {
    font-variant-numeric: tabular-nums;
  }
</style>
